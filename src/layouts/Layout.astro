---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Haeckelei – meine Website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        // Mobile back-button / back-gesture handling:
        // - If scrolled down, pressing Back should jump to absolute top (0,0) and stay.
        // - If already at absolute top, pressing Back should leave normally.
        //
        // On some browsers, navigating away and back restores the page from a
        // back/forward cache without re-running scripts. To keep behavior
        // consistent, we (re)initialize the handler on page show.

        function initBackScrollHandler() {
          if ((window as any).__backScrollHandlerInitialized) return;
          (window as any).__backScrollHandlerInitialized = true;

          try {
            history.pushState({ __scrollTopOnBack: true }, '', location.href);
          } catch {
            // Ignore environments where history state is unavailable.
          }

          window.addEventListener('popstate', () => {
            const scrollY = window.scrollY || 0;
            const atTop = scrollY <= 1;

            if (!atTop) {
              // Always jump fully to the very top (no smooth scrolling).
              const doc = document.documentElement;
              const body = document.body;
              if (doc) doc.scrollTop = 0;
              if (body) body.scrollTop = 0;
              window.scrollTo(0, 0);

              // Re-arm the "stay-on-page" behavior while user is scrolled down.
              try {
                history.pushState({ __scrollTopOnBack: true }, '', location.href);
              } catch {
                // Ignore.
              }
            }
            // If already at top, do nothing: normal back navigation proceeds.
          });
        }

        initBackScrollHandler();
        window.addEventListener('pageshow', () => {
          initBackScrollHandler();
        });
      })();
    </script>
  </body>
</html>


