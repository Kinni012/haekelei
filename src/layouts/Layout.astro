---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Haeckelei – meine Website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        // Mobile back-button / back-gesture handling:
        // - If scrolled down, pressing Back should jump to absolute top (0,0) and stay.
        // - If already at absolute top, pressing Back should leave normally.
        try {
          history.pushState({ __scrollTopOnBack: true }, '', location.href);
        } catch {
          // Ignore environments where history state is unavailable.
        }

        let isExiting = false;

        window.addEventListener('popstate', () => {
          if (isExiting) {
            isExiting = false;
            return;
          }

          const scrollY = window.scrollY || 0;
          const atTop = scrollY <= 8;

          if (!atTop) {
            // Always jump fully to the very top (no smooth scrolling).
            const doc = document.documentElement;
            const body = document.body;
            if (doc) doc.scrollTop = 0;
            if (body) body.scrollTop = 0;
            window.scrollTo(0, 0);

            // Re-arm the "stay-on-page" behavior by keeping an extra history
            // entry for the next Back while the user is scrolled down.
            try {
              history.pushState({ __scrollTopOnBack: true }, '', location.href);
            } catch {
              // Ignore.
            }
            return;
          }

          // Already at the top: allow leaving immediately.
          // We may currently be inside the "duplicate" history entry created above,
          // so we need to go back one more time to reach the real previous page.
          isExiting = true;
          history.back();
        });
      })();
    </script>
  </body>
</html>


