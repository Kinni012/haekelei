---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Haeckelei – meine Website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        // Make the first "Back" gesture scroll to top instead of leaving.
        // If already at the top, the next Back behaves normally.
        try {
          history.pushState({ __scrollTopOnBack: true }, '', location.href);
        } catch {
          // Ignore environments where history state is unavailable.
        }

        window.addEventListener('popstate', () => {
          // First "Back" within this page: jump to absolute top and stay.
          // Because we pushed a duplicate state on load, this popstate
          // only moves between two entries with the same URL/document,
          // so we don't need to push again here. A second Back will then
          // leave the page normally.
          const doc = document.documentElement;
          const body = document.body;
          if (doc) doc.scrollTop = 0;
          if (body) body.scrollTop = 0;
          window.scrollTo(0, 0);
        });
      })();
    </script>
  </body>
</html>


