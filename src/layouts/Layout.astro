---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Haeckelei – meine Website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        // Mobile back-button / back-gesture handling:
        // - If scrolled down, pressing Back should jump to absolute top (0,0) and stay.
        // - If already at absolute top, pressing Back should leave normally.
        //
        // On some browsers, navigating away and back restores the page from a
        // back/forward cache without re-running scripts. To keep behavior
        // consistent, we (re)initialize the handler on page show.

        function isArmed() {
          const st = history.state;
          return !!(st && typeof st === 'object' && st.__scrollTopOnBack === true);
        }

        function armIfNeeded() {
          if (isArmed()) return;
          try {
            history.pushState({ __scrollTopOnBack: true }, '', location.href);
          } catch {
            // Ignore environments where history state is unavailable.
          }
        }

        function initBackScrollHandler() {
          if (window.__backScrollHandlerInitialized) return;
          window.__backScrollHandlerInitialized = true;

          // Ensure we have a duplicate entry to intercept Back when scrolled.
          armIfNeeded();

          let skipping = false;

          window.addEventListener('popstate', () => {
            if (skipping) {
              skipping = false;
              return;
            }

            const scrollY = window.scrollY || 0;
            const atTop = scrollY <= 1;

            if (!atTop) {
              // Always jump fully to the very top (no smooth scrolling).
              const doc = document.documentElement;
              const body = document.body;
              if (doc) doc.scrollTop = 0;
              if (body) body.scrollTop = 0;
              window.scrollTo(0, 0);

              // Re-arm the "stay-on-page" behavior while user is scrolled down.
              armIfNeeded();
              return;
            }

            // At the very top: leave immediately (no "double back").
            // If we're currently stepping from the armed duplicate entry to the
            // original entry, go back one more time to actually leave.
            if (isArmed()) {
              skipping = true;
              history.back();
            }
          });
        }

        initBackScrollHandler();
        window.addEventListener('pageshow', () => {
          // When restored from back/forward cache, scripts might not re-run.
          // Re-arm the history entry in case we returned to an unarmed state.
          armIfNeeded();
          initBackScrollHandler();
        });
      })();
    </script>
  </body>
</html>


